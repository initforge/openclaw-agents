generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AgentConfig {
  id        String   @id @default(cuid())
  agentId   String
  version   Int      @default(1)
  enabled   Boolean  @default(true)
  mode      String
  createdAt DateTime @default(now())
}
