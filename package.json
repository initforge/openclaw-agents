{
  "name": "open-claw-ops-workspace",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "ci": "pnpm typecheck && pnpm lint && pnpm test:unit",
    "format": "biome check . --write",
    "clean": "node clean.mjs",
    "clean:deps": "node clean.mjs --deps",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "docker:dev:up": "docker compose -f infra/docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f infra/docker-compose.dev.yml down",
    "docker:prod:build": "docker compose -f infra/docker-compose.prod.yml build",
    "health:prod": "bash infra/health-check.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
